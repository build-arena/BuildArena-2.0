# Copy this file to `.env` and adjust values for your local machine.
# Keep real secrets and machine-specific paths out of version control.

# Project data files. Relative paths are resolved from the repository root.
BLOCK_REGISTRY_PATH=blocks/block_registry.generated.toml
BLOCK_ROLES_PATH=blocks/block_roles.toml
BLOCK_AUTHORING_PATH=blocks/block_authoring.toml
COLLIDER_DUMP_PATH=.local/collider_dump.toml

# Besiege_Data must be the Unity data directory, not the Besiege install root.
BESIEGE_DATA_PATH=C:\Program Files (x86)\Steam\steamapps\common\Besiege\Besiege_Data

# Directory where generated preview .bsg files are written.
SAVED_MACHINE_DIR=C:\Program Files (x86)\Steam\steamapps\common\Besiege\Besiege_Data\SavedMachines\BuildArena